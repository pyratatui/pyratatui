# ── TextArea ──────────────────────────────────────────────────────────────────

class TextArea:
    """Multi-line text editor widget powered by tui-textarea.

    Supports Emacs-style key bindings, undo/redo, yank/paste, line numbers,
    cursor line highlighting, and text selection.

    Example::

        ta = TextArea.from_lines(["Hello", "World"])
        ta.set_placeholder_text("Type here…")

        with Terminal() as term:
            while True:
                term.draw(lambda frame: frame.render_textarea(ta, frame.area))
                ev = term.poll_event(timeout_ms=50)
                if ev:
                    if ev.code == "Esc": break
                    ta.input_key(ev.code, ev.ctrl, ev.alt, ev.shift)

        print("\\n".join(ta.lines()))
    """

    def __init__(self) -> None: ...
    @staticmethod
    def from_lines(lines: list[str]) -> TextArea: ...

    # Key input
    def input_key(self, code: str, ctrl: bool, alt: bool, shift: bool) -> bool: ...
    def input_without_shortcuts(
        self, code: str, ctrl: bool, alt: bool, shift: bool
    ) -> bool: ...
    def insert_str(self, s: str) -> bool: ...

    # Editing operations
    def delete_char(self) -> bool: ...
    def delete_next_char(self) -> bool: ...
    def insert_newline(self) -> bool: ...
    def delete_line_by_end(self) -> bool: ...
    def delete_line_by_head(self) -> bool: ...
    def delete_word(self) -> bool: ...
    def delete_next_word(self) -> bool: ...

    # Cursor movement
    def move_cursor(self, m: CursorMove) -> None: ...
    def move_cursor_to(self, row: int, col: int) -> None: ...
    def scroll(self, s: Scrolling) -> None: ...

    # Undo/redo/clipboard
    def undo(self) -> bool: ...
    def redo(self) -> bool: ...
    def paste(self) -> bool: ...
    def start_selection(self) -> None: ...
    def cancel_selection(self) -> None: ...
    def cut(self) -> bool: ...
    def copy(self) -> None: ...

    # Accessors
    def lines(self) -> list[str]: ...
    def cursor(self) -> tuple[int, int]: ...
    def is_empty(self) -> bool: ...
    def len(self) -> int: ...
    def selection_range(self) -> tuple[tuple[int, int], tuple[int, int]] | None: ...

    # Styling
    def set_block(self, block: Block) -> None: ...
    def set_cursor_style(self, style: Style) -> None: ...
    def set_cursor_line_style(self, style: Style) -> None: ...
    def set_line_number_style(self, style: Style) -> None: ...
    def remove_line_number(self) -> None: ...
    def set_placeholder_text(self, text: str) -> None: ...
    def set_placeholder_style(self, style: Style) -> None: ...

    # Configuration
    def set_tab_length(self, n: int) -> None: ...
    def set_hard_tab_indent(self, enabled: bool) -> None: ...
    def set_max_histories(self, n: int) -> None: ...

