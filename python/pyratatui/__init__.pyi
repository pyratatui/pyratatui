# ── KnownSizeWrapper ──────────────────────────────────────────────────────────

class KnownSizeWrapper:
    """Wrap a list of text lines with explicit width/height for scrollable popups.

    Args:
        lines: List of text lines to display.
        width: Fixed display width of the content area (columns).
        height: Fixed display height of the content area (rows).
        scroll: Initial vertical scroll offset (default 0).

    Example::

        lines = [f"Line {i}" for i in range(20)]
        wrapper = KnownSizeWrapper(lines, width=30, height=8)
        popup = Popup(wrapper).title("Scrollable Content")
    """

    def __init__(
        self,
        lines: list[str],
        width: int,
        height: int,
        scroll: int = 0,
    ) -> None: ...
    def with_scroll(self, scroll: int) -> KnownSizeWrapper: ...
    @property
    def scroll(self) -> int: ...
    def scroll_down(self, n: int) -> None: ...
    def scroll_up(self, n: int) -> None: ...

# ── PopupState ────────────────────────────────────────────────────────────────

class PopupState:
    """State for a draggable/moveable popup.

    Pass to ``frame.render_stateful_popup()`` to enable position tracking.
    Use ``move_*`` for keyboard-driven movement, ``mouse_*`` for mouse drag.

    Example::

        state = PopupState()

        def ui(frame):
            popup = Popup("Hello!").title("Draggable")
            frame.render_stateful_popup(popup, frame.area, state)

        # Move with arrow keys:
        state.move_up(1)
        state.move_down(1)
        state.move_left(1)
        state.move_right(1)
    """

    def __init__(self) -> None: ...
    def move_up(self, n: int) -> None: ...
    def move_down(self, n: int) -> None: ...
    def move_left(self, n: int) -> None: ...
    def move_right(self, n: int) -> None: ...
    def move_to(self, x: int, y: int) -> None: ...
    def mouse_down(self, col: int, row: int) -> None: ...
    def mouse_up(self, col: int, row: int) -> None: ...
    def mouse_drag(self, col: int, row: int) -> None: ...
    def reset(self) -> None: ...

# ── Popup ─────────────────────────────────────────────────────────────────────

class Popup:
    """A centered popup widget.

    Accepts either a plain string body or a ``KnownSizeWrapper`` for
    scrollable content.  Use the builder methods to add a title and style.

    Rendering:

    - **Stateless** (fixed center): ``frame.render_popup(popup, frame.area)``
    - **Stateful** (draggable): ``frame.render_stateful_popup(popup, frame.area, state)``

    Example::

        from pyratatui import Popup, PopupState, Style, Color

        popup = (
            Popup("Press any key to exit")
            .title("tui-popup demo")
            .style(Style().fg(Color.white()).bg(Color.blue()))
        )

        state = PopupState()

        def ui(frame):
            frame.render_stateful_popup(popup, frame.area, state)
    """

    def __init__(self, content: str | KnownSizeWrapper) -> None: ...
    def title(self, title: str) -> Popup: ...
    def style(self, style: Style) -> Popup: ...

